{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "formatter": false,
  "permission": "allow",
  "plugin": ["oh-my-openagent@latest"],
  "mcp": {
    "gitcode": {
      "type": "local",
      "command": ["gitcode-mcp"],
      "environment": {
        "GITCODE_TOKEN": "{{ gitcode_token }}"
      }
    },
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey={{ tavily_api_key }}"
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"]
    }
  }
}
